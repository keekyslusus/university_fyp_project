{
  "name": "scandium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:electrobun",
    "dev:electrobun": "vite build && electrobun dev --watch",
    "dev:electrobun:hmr": "concurrently -k \"vite --port 5173\" \"electrobun dev --watch\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run build:electrobun",
    "build:electrobun": "vite build && electrobun build --env=stable",
    "build:electrobun:canary": "vite build && electrobun build --env=canary",
    "build:test": "tsc -p tsconfig.test.json",
    "release:win": "npm run build:electrobun",
    "preview": "vite preview",
    "test": "npm run build:test && node scripts/prepare-test-build.cjs && node .tmp-test/tests/run-tests.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "material-symbols": "^0.44.4",
    "solid-js": "^1.9.5",
    "vite": "^6.2.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.13.10",
    "@types/three": "^0.184.0",
    "bun": "^1.3.13",
    "concurrently": "^9.1.2",
    "electrobun": "^1.17.3-beta.12",
    "rcedit": "^5.0.2",
    "typescript": "^5.8.2"
  }
}
